{
  "AppSettings": {
    "EnvironmentName": "Development",
    "Infrastructure": {
      "Database": {
        "DatabaseType": "PostgreSQL",
        "ConnectionString": "Host=localhost;Database=ProjectTemplate;Username=postgres;Password=PostgresPass123;Port=5433",
        "ReadOnlyConnectionString": "Host=localhost;Database=ProjectTemplate;Username=postgres;Password=PostgresPass123;Port=5433",
        "CommandTimeoutSeconds": 30,
        "EnableSensitiveDataLogging": true,
        "EnableDetailedErrors": true
      },
      "MongoDB": {
        "ConnectionString": "mongodb://admin:admin@localhost:27017/ProjectTemplate"
      },
      "RabbitMQ": {
        "ConnectionString": "amqp://guest:guest@localhost:5672"
      },
      "Redis": {
        "ConnectionString": "localhost:6379"
      },
      "Storage": {
        "Provider": "Google",
        "DefaultBucket": "",
        "Google": {
          "ServiceAccount": "",
          "ProjectId": ""
        },
        "Azure": {
          "ConnectionString": "",
          "BlobServiceUri": "",
          "ManagedIdentityClientId": ""
        },
        "Aws": {
          "AccessKeyId": "",
          "SecretAccessKey": "",
          "Region": "us-east-1",
          "Profile": "",
          "ServiceUrl": ""
        }
      },
      "Telemetry": {
        "Enabled": false,
        "Providers": [],
        "SamplingRatio": 1.0,
        "EnableSqlInstrumentation": true,
        "EnableHttpInstrumentation": true,
        "Jaeger": {
          "Host": "localhost",
          "Port": 4317,
          "UseGrpc": true
        },
        "Zipkin": {
          "Endpoint": "http://localhost:9411/api/v2/spans"
        },
        "Otlp": {
          "Endpoint": "http://localhost:4317",
          "Protocol": "grpc",
          "Headers": ""
        },
        "ApplicationInsights": {
          "ConnectionString": "",
          "EnableAdaptiveSampling": true,
          "EnableLiveMetrics": true
        },
        "Datadog": {
          "Endpoint": "http://localhost:4317",
          "ApiKey": "",
          "Site": "datadoghq.com",
          "Environment": "development"
        },
        "Dynatrace": {
          "Endpoint": "",
          "ApiToken": "",
          "Environment": "development"
        }
      },
      "RateLimiting": {
        "Enabled": false,
        "DefaultPolicy": "fixed",
        "WhitelistedIps": [],
        "Policies": {
          "FixedWindow": {
            "Enabled": true,
            "PermitLimit": 100,
            "Window": "00:01:00",
            "QueueLimit": 10
          },
          "SlidingWindow": {
            "Enabled": true,
            "PermitLimit": 100,
            "Window": "00:01:00",
            "SegmentsPerWindow": 6,
            "QueueLimit": 10
          },
          "TokenBucket": {
            "Enabled": true,
            "TokenLimit": 100,
            "ReplenishmentPeriod": "00:00:10",
            "TokensPerPeriod": 10,
            "AutoReplenishment": true,
            "QueueLimit": 10
          },
          "Concurrency": {
            "Enabled": true,
            "PermitLimit": 50,
            "QueueLimit": 100
          }
        }
      },
      "EventSourcing": {
        "Enabled": true,
        "Mode": "Hybrid",
        "Provider": "Marten",
        "ConnectionString": "Host=localhost;Database=ProjectTemplateEvents;Username=postgres;Password=postgres;Port=5432",
        "AuditEntities": [],
        "StoreSnapshots": true,
        "SnapshotInterval": 10,
        "EnableAuditApi": true,
        "StoreMetadata": true
      }
    },
    "Authentication": {
      "Enabled": true,
      "Jwt": {
        "Secret": "your-256-bit-secret-key-change-this-in-production-needs-at-least-32-characters",
        "Issuer": "ProjectTemplate",
        "Audience": "ProjectTemplate",
        "ExpirationMinutes": 60,
        "RefreshTokenExpirationDays": 7,
        "ValidateIssuer": true,
        "ValidateAudience": true,
        "ValidateLifetime": true,
        "ValidateIssuerSigningKey": true
      },
      "OAuth2": {
        "Enabled": false,
        "Google": {
          "Enabled": false,
          "ClientId": "",
          "ClientSecret": ""
        },
        "Microsoft": {
          "Enabled": false,
          "ClientId": "",
          "ClientSecret": "",
          "TenantId": "common"
        },
        "GitHub": {
          "Enabled": false,
          "ClientId": "",
          "ClientSecret": ""
        }
      },
      "PasswordPolicy": {
        "MinimumLength": 8,
        "RequireDigit": true,
        "RequireLowercase": true,
        "RequireUppercase": true,
        "RequireNonAlphanumeric": true,
        "MaxFailedAccessAttempts": 5,
        "LockoutMinutes": 15
      },
      "RefreshToken": {
        "ExpirationDays": 7,
        "ReuseTokens": false
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*"
}