<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:EnterpriseTemplate.MauiApp.Converters"
             x:Class="EnterpriseTemplate.MauiApp.Pages.OrdersPage"
             Title="Pedidos"
             BackgroundColor="{StaticResource Gray50}">

    <ContentPage.Resources>
        <conv:StatusColorConverter x:Key="StatusColorConverter" />
        <conv:CurrencyConverter x:Key="CurrencyConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, Auto, *">
        <!-- Header area -->
        <VerticalStackLayout Grid.Row="0" Padding="20,20,20,10" Spacing="4">
            <Label Text="Pedidos" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource Gray900}" />
            <Label Text="Acompanhamento de vendas e status" FontSize="14" TextColor="{StaticResource Gray500}" />
        </VerticalStackLayout>

        <!-- Filters area -->
        <VerticalStackLayout Grid.Row="1" Padding="20,10" Spacing="16">
            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                <Frame Grid.Column="0" BackgroundColor="White" CornerRadius="20" Padding="0" HasShadow="False" BorderColor="{StaticResource Gray200}">
                    <Grid ColumnDefinitions="Auto, *">
                        <Label Grid.Column="0" Text="🔍" VerticalOptions="Center" Margin="16,0,0,0" />
                        <Entry Grid.Column="1" x:Name="SearchEntry" 
                               Placeholder="Número ou cliente..." 
                               Margin="10,8" 
                               BackgroundColor="Transparent"
                               Completed="OnSearchCompleted" />
                    </Grid>
                </Frame>
                
                <Button Grid.Column="1" Text="📅" FontSize="20" 
                        BackgroundColor="{StaticResource Primary50}" 
                        TextColor="{StaticResource Primary}" 
                        CornerRadius="20" WidthRequest="56" HeightRequest="56"
                        Clicked="OnDateFilterClicked" />
            </Grid>

            <HorizontalStackLayout Spacing="8">
                <Button x:Name="BtnAll" Text="TODOS" Clicked="OnFilterAll" Style="{StaticResource FilterButtonStyle}" />
                <Button x:Name="BtnPending" Text="PENDENTES" Clicked="OnFilterPending" Style="{StaticResource FilterButtonStyle}" />
                <Button x:Name="BtnShipped" Text="ENVIADOS" Clicked="OnFilterShipped" Style="{StaticResource FilterButtonStyle}" />
                <Button x:Name="BtnDelivered" Text="ENTREGUES" Clicked="OnFilterDelivered" Style="{StaticResource FilterButtonStyle}" />
            </HorizontalStackLayout>
            
            <Label x:Name="DateRangeLabel" IsVisible="False" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Primary}" HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- List area -->
        <RefreshView Grid.Row="2" x:Name="RefreshView" Refreshing="OnRefreshing" RefreshColor="{StaticResource Primary}">
            <VerticalStackLayout Spacing="0">
                <ActivityIndicator x:Name="LoadingIndicator" Color="{StaticResource Primary}" IsRunning="True" IsVisible="True" Margin="0,40,0,0" />

                <CollectionView x:Name="OrdersList" IsVisible="False" Margin="20,0,20,20"
                                RemainingItemsThreshold="2" RemainingItemsThresholdReached="OnRemainingItemsReached">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Margin="0,0,0,16" BackgroundColor="White" CornerRadius="24" Padding="20" HasShadow="False" BorderColor="{StaticResource Gray100}">
                                <VerticalStackLayout Spacing="12">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Label Grid.Column="0" Text="{Binding OrderNumber, StringFormat='#{0}'}" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource Gray900}" />
                                        
                                        <!-- Custom Status badge -->
                                        <Frame Grid.Column="1" BackgroundColor="{StaticResource Gray50}" CornerRadius="10" Padding="12,6" HasShadow="False">
                                            <Label Text="{Binding Status}" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                                        </Frame>
                                    </Grid>

                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="👤" FontSize="14" VerticalOptions="Center" />
                                        <Label Text="{Binding CustomerName}" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource Gray700}" />
                                    </HorizontalStackLayout>

                                    <BoxView HeightRequest="1" Color="{StaticResource Gray50}" Margin="0,4" />

                                    <Grid ColumnDefinitions="*, Auto">
                                        <VerticalStackLayout Grid.Column="0">
                                            <Label Text="TOTAL" FontSize="9" FontAttributes="Bold" TextColor="{StaticResource Gray400}" CharacterSpacing="1.1" />
                                            <Label Text="{Binding Total, Converter={StaticResource CurrencyConverter}}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                                        </VerticalStackLayout>
                                        
                                        <HorizontalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="End">
                                            <Button Text="🔍" Clicked="OnViewDetailsClicked" BackgroundColor="Transparent" Padding="0" WidthRequest="40" HeightRequest="40" CornerRadius="20" FontSize="18" />
                                            <Button Text="✏️" Clicked="OnEditClicked" BackgroundColor="Transparent" Padding="0" WidthRequest="40" HeightRequest="40" CornerRadius="20" FontSize="18" />
                                        </HorizontalStackLayout>
                                    </Grid>
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                
                <VerticalStackLayout x:Name="EmptyState" IsVisible="False" HorizontalOptions="Center" Margin="0,60,0,0" Spacing="12">
                    <Label Text="📭" FontSize="64" HorizontalOptions="Center" />
                    <Label Text="Nenhum pedido encontrado" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource Gray400}" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </RefreshView>
    </Grid>
</ContentPage>
