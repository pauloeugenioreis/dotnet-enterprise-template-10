<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EnterpriseTemplate.MauiApp.Pages.ProductsPage"
             Title="Produtos"
             BackgroundColor="#F8FAFC">

    <RefreshView x:Name="RefreshView" Refreshing="OnRefreshing" RefreshColor="#0284c7">
        <VerticalStackLayout Padding="20" Spacing="16">
            <Label Text="Catálogo de Produtos" FontSize="22" FontAttributes="Bold" TextColor="#0F172A" />

            <ActivityIndicator x:Name="LoadingIndicator" Color="#0284c7" IsRunning="True" IsVisible="True" />

            <CollectionView x:Name="ProductsList" IsVisible="False">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,4" BackgroundColor="White" CornerRadius="20" Padding="12" HasShadow="True">
                            <Grid ColumnDefinitions="60, *, Auto" ColumnSpacing="12">
                                <Frame Grid.Column="0" BackgroundColor="#F0F9FF" CornerRadius="12" Padding="0" HasShadow="False" HeightRequest="60">
                                    <Label Text="📦" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Frame>

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="{Binding Name}" FontSize="15" FontAttributes="Bold" TextColor="#0F172A" />
                                    <Label Text="{Binding Category}" FontSize="12" TextColor="#64748B" />
                                    <Label Text="{Binding StockQuantity, StringFormat='{0} em estoque'}" FontSize="11" TextColor="#0284c7" Margin="0,2,0,0" />
                                </VerticalStackLayout>

                                <Label Grid.Column="2" Text="{Binding Price, StringFormat='R$ {0:N2}'}" FontSize="16" FontAttributes="Bold" TextColor="#0F172A" VerticalOptions="Center" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </RefreshView>
</ContentPage>
