<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Enterprise Premium Palette -->
    <Color x:Key="Primary">#0284C7</Color>
    <Color x:Key="Primary50">#F0F9FF</Color>
    <Color x:Key="Primary100">#E0F2FE</Color>
    <Color x:Key="Primary600">#0284C7</Color>
    <Color x:Key="Primary700">#0369A1</Color>
    
    <Color x:Key="Gray50">#F8FAFC</Color>
    <Color x:Key="Gray100">#F1F5F9</Color>
    <Color x:Key="Gray200">#E2E8F0</Color>
    <Color x:Key="Gray400">#94A3B8</Color>
    <Color x:Key="Gray500">#64748B</Color>
    <Color x:Key="Gray700">#334155</Color>
    <Color x:Key="Gray900">#0F172A</Color>

    <Color x:Key="Success">#10B981</Color>
    <Color x:Key="SuccessBg">#ECFDF5</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="WarningBg">#FFFBEB</Color>
    <Color x:Key="Error">#E11D48</Color>
    <Color x:Key="ErrorBg">#FEF2F2</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>

</ResourceDictionary>