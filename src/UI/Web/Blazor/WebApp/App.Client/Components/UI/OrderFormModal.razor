@using ProjectTemplate.Shared.Models
@using BlazorApp.Client.Services
@inject IProductService ProductService

@if (IsOpen)
{
    <div class="fixed inset-0 z-50 flex items-center justify-end font-sans">
        <div class="absolute inset-0 bg-gray-900/40 backdrop-blur-sm" @onclick="Close"></div>
        
        <div class="relative w-full max-w-2xl h-full bg-white shadow-2xl animate-in slide-in-from-right duration-500 flex flex-col">
            <header class="p-8 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
                <div>
                    <h2 class="text-2xl font-black text-gray-900 tracking-tight">
                        @(IsEdit ? $"Editar Pedido #{OrderNumber}" : "Novo Pedido")
                    </h2>
                    <p class="text-gray-500 text-sm mt-1">@(IsEdit ? "Atualize as informações do pedido" : "Cadastre um novo pedido no sistema")</p>
                </div>
                <button @onclick="Close" class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white border border-gray-100 text-gray-400 hover:text-rose-600 transition-all active:scale-90 shadow-sm">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </header>

            <div class="flex-1 overflow-y-auto p-8 space-y-10">
                <!-- Seção: Informações do Cliente -->
                <div class="space-y-6">
                    <p class="text-[10px] uppercase tracking-widest text-gray-400 font-bold">Informações do Cliente</p>
                    <div class="grid grid-cols-1 gap-6">
                        <div class="space-y-2">
                            <label class="block text-[10px] font-black uppercase tracking-widest text-gray-400">Nome Completo</label>
                            <input type="text" @bind="customerName" class="w-full px-6 py-4 bg-gray-50 border border-gray-100 rounded-2xl outline-none font-bold text-gray-900 focus:bg-white focus:border-primary-200 focus:ring-4 focus:ring-primary-500/5 transition-all" placeholder="Nome do cliente" />
                        </div>
                        <div class="space-y-2">
                            <label class="block text-[10px] font-black uppercase tracking-widest text-gray-400">E-mail de Contato</label>
                            <input type="email" @bind="customerEmail" class="w-full px-6 py-4 bg-gray-50 border border-gray-100 rounded-2xl outline-none font-bold text-gray-900 focus:bg-white focus:border-primary-200 focus:ring-4 focus:ring-primary-500/5 transition-all" placeholder="email@exemplo.com" />
                        </div>
                    </div>
                </div>

                <!-- Seção: Endereço -->
                <div class="space-y-6">
                    <p class="text-[10px] uppercase tracking-widest text-gray-400 font-bold">Endereço de Entrega</p>
                    <input type="text" @bind="shippingAddress" class="w-full px-6 py-4 bg-gray-50 border border-gray-100 rounded-2xl outline-none font-bold text-gray-900 focus:bg-white focus:border-primary-200 focus:ring-4 focus:ring-primary-500/5 transition-all" placeholder="Rua, Número, Cidade - UF, CEP" />
                </div>

                <!-- Seção: Itens -->
                <div class="space-y-6">
                    <div class="flex justify-between items-center">
                        <p class="text-[10px] uppercase tracking-widest text-gray-400 font-bold">Itens do Pedido</p>
                        <button @onclick="AddItem" class="text-primary-600 font-black text-[10px] uppercase tracking-widest hover:text-primary-700 flex items-center gap-2 group">
                            <span class="text-lg group-hover:scale-125 transition-transform">+</span>
                            Adicionar Item
                        </button>
                    </div>

                    <div class="space-y-4">
                        @foreach (var item in items)
                        {
                            <div class="p-4 bg-gray-50 rounded-2xl border border-gray-100 flex gap-4 items-end">
                                <div class="flex-1">
                                    <label class="block text-[8px] font-black uppercase tracking-widest text-gray-300 mb-1">Produto</label>
                                    <Dropdown 
                                        Options="productOptions" 
                                        Value="@item.ProductId.ToString()" 
                                        ValueChanged="@(val => OnProductSelected(item, val))" 
                                        Placeholder="Selecionar Produto" 
                                        Variant="form"
                                        Loading="productLoading"
                                        OnLoadMore="HandleLoadMoreProducts" />
                                </div>
                                <div class="w-24">
                                    <label class="block text-[8px] font-black uppercase tracking-widest text-gray-300 mb-1">Qtd</label>
                                    <input type="number" @bind="item.Quantity" class="w-full px-4 py-3 bg-white border border-gray-100 rounded-xl outline-none font-bold text-sm text-gray-900 text-center" min="1" />
                                </div>
                                <button @onclick="() => RemoveItem(item)" class="w-10 h-10 flex items-center justify-center text-red-300 hover:text-red-500 hover:bg-red-50 rounded-xl transition-all">
                                    ✕
                                </button>
                            </div>
                        }

                        @if (items.Count == 0)
                        {
                            <div class="text-center py-10 border-2 border-dashed border-gray-100 rounded-[2rem]">
                                <p class="text-gray-300 text-sm font-medium italic">Nenhum item adicionado ao pedido.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <footer class="p-8 border-t border-gray-100 bg-gray-50/50 flex gap-4">
                <button @onclick="Close" class="flex-1 py-5 rounded-3xl bg-white border border-gray-100 text-[10px] font-black text-gray-400 uppercase tracking-widest hover:bg-gray-100 transition-all active:scale-95">
                    Cancelar
                </button>
                <button 
                    @onclick="Save" 
                    disabled="@(items.Count == 0)"
                    class="flex-[2] bg-primary-600 hover:bg-primary-700 disabled:opacity-50 disabled:cursor-not-allowed text-white font-black py-5 rounded-3xl shadow-xl shadow-primary-600/20 transition-all active:scale-95 flex items-center justify-center gap-3 tracking-widest text-[10px] uppercase"
                >
                    <span>@(IsEdit ? "Salvar Alterações" : "Criar Pedido")</span>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                </button>
            </footer>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public bool IsEdit { get; set; }
    [Parameter] public OrderResponseDto? Order { get; set; }
    [Parameter] public string? OrderNumber { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<OrderResponseDto> OnSave { get; set; }

    private string customerName = "";
    private string customerEmail = "";
    private string shippingAddress = "";
    private string status = "Pending";
    private decimal total = 0;
    private List<OrderItemModel> items = new();
    private List<DropdownOption> productOptions = new();
    private int productPage = 1;
    private bool productLoading = false;
    private bool hasMoreProducts = true;

    private class OrderItemModel
    {
        public long ProductId { get; set; }
        public string ProductName { get; set; } = "";
        public int Quantity { get; set; } = 1;
        public decimal UnitPrice { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts(bool isLoadMore = false)
    {
        if (productLoading || (!hasMoreProducts && isLoadMore)) return;

        productLoading = true;
        try 
        {
            var result = await ProductService.GetPagedAsync(productPage, 20, null, true);
            var newOptions = result.Items.Select(p => new DropdownOption 
            { 
                Label = $"{p.Name} - {p.Price:C}", 
                Value = p.Id.ToString() 
            }).ToList();

            if (isLoadMore)
            {
                productOptions.AddRange(newOptions);
            }
            else
            {
                productOptions = newOptions;
            }

            hasMoreProducts = result.Items.Count() == 20;
            if (hasMoreProducts) productPage++;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar produtos: {ex.Message}");
        }
        finally
        {
            productLoading = false;
        }
    }

    private async Task HandleLoadMoreProducts()
    {
        await LoadProducts(true);
    }

    protected override void OnParametersSet()
    {
        if (IsOpen)
        {
            if (IsEdit && Order != null)
            {
                customerName = Order.CustomerName;
                customerEmail = Order.CustomerEmail;
                shippingAddress = Order.ShippingAddress;
                status = Order.Status;
                items = Order.Items?.Select(i => new OrderItemModel 
                { 
                    ProductId = i.ProductId, 
                    ProductName = i.ProductName, 
                    Quantity = i.Quantity, 
                    UnitPrice = i.UnitPrice 
                }).ToList() ?? new();
                CalculateTotal();
            }
            else
            {
                Reset();
            }
        }
    }

    private void Reset()
    {
        customerName = "";
        customerEmail = "";
        shippingAddress = "";
        status = "Pending";
        total = 0;
        items = new();
        CalculateTotal();
    }

    private void AddItem()
    {
        items.Add(new OrderItemModel());
        CalculateTotal();
    }

    private void RemoveItem(OrderItemModel item)
    {
        items.Remove(item);
        CalculateTotal();
    }

    private void CalculateTotal()
    {
        total = items.Sum(i => i.UnitPrice * i.Quantity);
    }

    private async Task OnProductSelected(OrderItemModel item, object? val)
    {
        if (val == null) return;
        
        var productIdStr = val.ToString();
        if (long.TryParse(productIdStr, out long productId))
        {
            item.ProductId = productId;
            // Fetch product details to update price and name
            try 
            {
                var product = (await ProductService.GetPagedAsync(1, 100)).Items.FirstOrDefault(p => p.Id == productId);
                if (product != null)
                {
                    item.ProductName = product.Name;
                    item.UnitPrice = product.Price;
                    CalculateTotal();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Erro ao carregar detalhes do produto: {ex.Message}");
            }
        }
    }

    private async Task Close() => await OnClose.InvokeAsync();

    private async Task Save()
    {
        var savedOrder = (Order ?? new OrderResponseDto()) with 
        {
            CustomerName = customerName,
            CustomerEmail = customerEmail,
            ShippingAddress = shippingAddress,
            Status = status,
            Total = total,
            Items = items.Select(i => new OrderItemResponseDto 
            { 
                ProductId = i.ProductId, 
                ProductName = i.ProductName, 
                Quantity = i.Quantity, 
                UnitPrice = i.UnitPrice,
                Subtotal = i.Quantity * i.UnitPrice
            }).ToList()
        };
        
        await OnSave.InvokeAsync(savedOrder);
        await Close();
    }
}
