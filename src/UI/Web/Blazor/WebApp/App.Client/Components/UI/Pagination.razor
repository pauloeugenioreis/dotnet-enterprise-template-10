@namespace BlazorApp.Components.UI

<div class="flex items-center justify-between mt-10 px-10 py-8 bg-white rounded-[3rem] shadow-2xl shadow-gray-200/40 border border-gray-50">
    <!-- Left: Page Info -->
    <div class="flex items-center gap-1">
        <span class="text-[11px] font-bold text-gray-500 uppercase tracking-widest">Página </span>
        <span class="text-[14px] font-black text-gray-900 mx-1">@Page</span>
        <span class="text-[11px] font-bold text-gray-500 uppercase tracking-widest"> de </span>
        <span class="text-[14px] font-black text-gray-900 ml-1">@TotalPages</span>
    </div>

    <!-- Center: Page Size Selector -->
    <div class="flex items-center gap-4">
        <span class="text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]">Itens por página:</span>
        <div class="relative">
            <select 
                @onchange="OnPageSizeChange"
                class="appearance-none bg-gray-50 border border-gray-100 rounded-2xl px-6 py-3 pr-10 text-xs font-black text-gray-900 outline-none focus:ring-2 focus:ring-primary-600/10 transition-all cursor-pointer"
            >
                @foreach (var size in PageSizes)
                {
                    <option value="@size" selected="@(size == PageSize)">@size</option>
                }
            </select>
            <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none">
                <svg class="w-3 h-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" />
                </svg>
            </div>
        </div>
    </div>

    <!-- Right: Navigation Buttons -->
    <div class="flex gap-4">
        <button 
            @onclick="() => OnPageChange(Page - 1)"
            disabled="@(Page <= 1)"
            class="px-8 py-4 rounded-2xl bg-white border border-gray-100 text-[10px] font-black text-gray-500 uppercase tracking-[0.2em] hover:bg-gray-50 disabled:opacity-30 disabled:hover:bg-white transition-all active:scale-95 shadow-sm"
        >
            Anterior
        </button>
        <button 
            @onclick="() => OnPageChange(Page + 1)"
            disabled="@(Page >= TotalPages)"
            class="px-8 py-4 rounded-2xl bg-primary-600 text-[10px] font-black text-white uppercase tracking-[0.2em] hover:bg-primary-700 shadow-lg shadow-primary-600/20 disabled:opacity-30 disabled:hover:bg-primary-600 transition-all active:scale-95"
        >
            Próxima
        </button>
    </div>
</div>

@code {
    [Parameter] public int Page { get; set; }
    [Parameter] public int TotalPages { get; set; }
    [Parameter] public long TotalItems { get; set; }
    [Parameter] public int PageSize { get; set; } = 10;
    [Parameter] public EventCallback<int> OnPageChanged { get; set; }
    [Parameter] public EventCallback<int> OnPageSizeChanged { get; set; }

    private List<int> PageSizes = new() { 5, 10, 20, 50 };

    private async Task OnPageChange(int newPage)
    {
        if (newPage >= 1 && newPage <= TotalPages)
        {
            await OnPageChanged.InvokeAsync(newPage);
        }
    }

    private async Task OnPageSizeChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var newSize))
        {
            await OnPageSizeChanged.InvokeAsync(newSize);
        }
    }
}
