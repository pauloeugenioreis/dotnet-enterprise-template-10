@using BlazorApp.Client.Services.Base
@using Microsoft.AspNetCore.Components.Authorization
@using BlazorApp.Client.Auth
@inject LocalStorageService LocalStorage
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<div class="flex flex-col h-full py-10 px-6">
    <!-- Brand -->
    <div class="flex items-center gap-4 px-3 mb-12 group cursor-pointer">
        <div class="w-12 h-12 bg-primary-600 rounded-2xl flex items-center justify-center text-white shadow-xl shadow-primary-500/30 group-hover:rotate-6 transition-all font-black text-2xl">
            ET
        </div>
        <span class="text-2xl font-black text-gray-900 tracking-tight">Enterprise</span>
    </div>

    <!-- Navigation Links -->
    <AuthorizeView>
        <Authorized>
            <nav class="flex-1 space-y-3">
                <NavLink href="dashboard" class="flex items-center gap-4 px-5 py-4 rounded-2xl text-sm font-bold transition-all hover:bg-gray-50 text-gray-400" ActiveClass="bg-primary-50 !text-primary-600 shadow-sm">
                    <span class="text-xl">📊</span>
                    Dashboard
                </NavLink>

                <NavLink href="products" class="flex items-center gap-4 px-5 py-4 rounded-2xl text-sm font-bold transition-all hover:bg-gray-50 text-gray-400" ActiveClass="bg-primary-50 !text-primary-600 shadow-sm">
                    <span class="text-xl">📦</span>
                    Produtos
                </NavLink>

                <NavLink href="orders" class="flex items-center gap-4 px-5 py-4 rounded-2xl text-sm font-bold transition-all hover:bg-gray-50 text-gray-400" ActiveClass="bg-primary-50 !text-primary-600 shadow-sm">
                    <span class="text-xl">🛍️</span>
                    Pedidos
                </NavLink>

                <NavLink href="audit" class="flex items-center gap-4 px-5 py-4 rounded-2xl text-sm font-bold transition-all hover:bg-gray-50 text-gray-400" ActiveClass="bg-primary-50 !text-primary-600 shadow-sm">
                    <span class="text-xl">🛡️</span>
                    Auditoria
                </NavLink>

                <NavLink href="documents" class="flex items-center gap-4 px-5 py-4 rounded-2xl text-sm font-bold transition-all hover:bg-gray-50 text-gray-400" ActiveClass="bg-primary-50 !text-primary-600 shadow-sm">
                    <span class="text-xl">📄</span>
                    Documentos
                </NavLink>
            </nav>

            <!-- Bottom Profile Card -->
            <div class="mt-auto pt-8 border-t border-gray-50">
                <div class="p-5 bg-gray-50/50 rounded-[2rem] border border-gray-100">
                    <div class="flex items-center gap-4 mb-4">
                        <div class="w-12 h-12 bg-white rounded-2xl shadow-sm border border-gray-100 flex items-center justify-center text-primary-600 font-black text-lg">
                            @context.User.Identity?.Name?[0]
                        </div>
                        <div class="flex-1 overflow-hidden">
                            <p class="text-sm font-black text-gray-900 truncate">@context.User.Identity?.Name</p>
                            <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">Administrador</p>
                        </div>
                    </div>
                    <button 
                        @onclick="HandleLogout" 
                        class="w-full py-3 px-4 bg-white hover:bg-rose-50 text-rose-600 text-[10px] font-black uppercase tracking-[0.2em] rounded-xl border border-gray-100 transition-all flex items-center justify-center gap-2"
                    >
                        <span>🚪</span>
                        Sair
                    </button>
                </div>
            </div>
        </Authorized>
        <NotAuthorized>
            <nav class="flex-1 space-y-2">
                <NavLink href="login" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-sm font-bold transition-all hover:bg-gray-50 text-gray-500" ActiveClass="bg-primary-50 !text-primary-600 shadow-sm">
                    <span>🔑</span>
                    Fazer Login
                </NavLink>
            </nav>
        </NotAuthorized>
    </AuthorizeView>
</div>

@code {
    private async Task HandleLogout()
    {
        await LocalStorage.RemoveItemAsync("authToken");
        ((CustomAuthenticationStateProvider)AuthStateProvider).NotifyUserLogout();
        Navigation.NavigateTo("/login");
    }
}
