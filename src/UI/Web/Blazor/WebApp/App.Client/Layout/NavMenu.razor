@using BlazorApp.Client.Services.Base
@using Microsoft.AspNetCore.Components.Authorization
@using BlazorApp.Client.Auth
@inject LocalStorageService LocalStorage
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@implements IDisposable

<div class="flex flex-col h-full">
    <!-- Brand -->
    <div class="p-10 border-b border-gray-50 flex items-center gap-4">
        <div class="w-12 h-12 bg-primary-600 rounded-[1.25rem] flex items-center justify-center text-white font-black text-2xl shadow-xl shadow-primary-600/20">
            ET
        </div>
        <div class="flex flex-col">
            <span class="font-black text-2xl text-gray-900 tracking-tighter">Enterprise</span>
            <span class="text-[10px] font-bold text-primary-600 uppercase tracking-[0.3em] -mt-1">Blazor Edition</span>
        </div>
    </div>

    <!-- Navigation Links -->
    <AuthorizeView>
        <Authorized>
            <nav class="mt-10 px-6 space-y-3 flex-1">
                <NavLink href="dashboard" class="@GetActiveClass("dashboard")">
                    <span class="text-xl group-hover:scale-110 transition-transform">📊</span>
                    <span class="font-black text-xs uppercase tracking-widest">Dashboard</span>
                </NavLink>

                <NavLink href="products" class="@GetActiveClass("products")">
                    <span class="text-xl group-hover:scale-110 transition-transform">📦</span>
                    <span class="font-black text-xs uppercase tracking-widest">Produtos</span>
                </NavLink>

                <NavLink href="orders" class="@GetActiveClass("orders")">
                    <span class="text-xl group-hover:scale-110 transition-transform">🛍️</span>
                    <span class="font-black text-xs uppercase tracking-widest">Pedidos</span>
                </NavLink>

                <NavLink href="audit" class="@GetActiveClass("audit")">
                    <span class="text-xl group-hover:scale-110 transition-transform">🛡️</span>
                    <span class="font-black text-xs uppercase tracking-widest">Auditoria</span>
                </NavLink>

                <NavLink href="documents" class="@GetActiveClass("documents")">
                    <span class="text-xl group-hover:scale-110 transition-transform">📄</span>
                    <span class="font-black text-xs uppercase tracking-widest">Documentos</span>
                </NavLink>
            </nav>

            <!-- User Section -->
            <div class="p-8 border-t border-gray-100 flex flex-col gap-6 bg-gray-50/30">
                <div class="flex items-center gap-4 group cursor-default">
                    @{
                        var email = context.User.FindFirst(c => c.Type.Contains("email"))?.Value ?? "admin@projecttemplate.com";
                        var name = context.User.Identity?.Name;
                        if (string.IsNullOrEmpty(name) || name == "ADMINISTRADOR" || email == "admin@projecttemplate.com") {
                            name = "System Administrator";
                        }
                        var initial = name[0].ToString().ToUpper();
                    }
                    <div class="w-14 h-14 bg-gradient-to-br from-primary-500 to-primary-700 rounded-2xl flex items-center justify-center text-white font-black text-2xl shadow-xl shadow-primary-200 group-hover:scale-110 transition-transform">
                        @initial
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-black text-gray-900 truncate tracking-tight">@name</p>
                        <p class="text-[10px] text-gray-400 font-bold truncate uppercase tracking-widest">@email</p>
                    </div>
                </div>
                <button 
                    @onclick="HandleLogout" 
                    class="w-full flex items-center justify-center gap-3 px-6 py-4 bg-white border border-red-100 text-red-500 rounded-2xl hover:bg-red-600 hover:text-white hover:border-red-600 transition-all duration-300 text-[11px] font-black uppercase tracking-widest active:scale-95 shadow-sm hover:shadow-xl hover:shadow-red-600/20 group/logout"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover/logout:translate-x-1 transition-transform">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                        <polyline points="16 17 21 12 16 7"></polyline>
                        <line x1="21" y1="12" x2="9" y2="12"></line>
                    </svg>
                    Sair da Conta
                </button>
            </div>
        </Authorized>
        <NotAuthorized>
            <nav class="flex-1 px-6 mt-10 space-y-3">
                <NavLink href="login" class="@GetActiveClass("login")">
                    <span>🔑</span>
                    <span class="font-black text-xs uppercase tracking-widest">Fazer Login</span>
                </NavLink>
            </nav>
        </NotAuthorized>
    </AuthorizeView>
</div>

@code {
    protected override void OnInitialized()
    {
        Navigation.LocationChanged += HandleLocationChanged;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e) => StateHasChanged();

    private string GetActiveClass(string page)
    {
        var currentUri = Navigation.ToBaseRelativePath(Navigation.Uri).ToLower();
        var isActive = currentUri.Contains(page.ToLower());
        
        // Special case for root/dashboard
        if (page == "dashboard" && (string.IsNullOrEmpty(currentUri) || currentUri == "/")) isActive = true;

        var baseClasses = "flex items-center gap-4 px-6 py-4 rounded-2xl transition-all duration-300 group";
        return isActive 
            ? $"{baseClasses} bg-primary-600 text-white shadow-lg shadow-primary-600/30" 
            : $"{baseClasses} text-gray-400 hover:bg-gray-50 hover:text-gray-900";
    }

    private async Task HandleLogout()
    {
        await LocalStorage.RemoveItemAsync("authToken");
        ((CustomAuthenticationStateProvider)AuthStateProvider).NotifyUserLogout();
        Navigation.NavigateTo("/login");
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
    }
}
