@page "/audit"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using BlazorApp.Client.Services
@using ProjectTemplate.Shared.Models
@using ProjectTemplate.Domain.Entities
@inject IAuditService AuditService
@rendermode InteractiveAuto

<div class="w-full space-y-10 animate-in fade-in duration-700">
  <header>
    <h1 class="text-6xl font-black text-gray-900 tracking-tighter">Auditoria</h1>
    <p class="text-gray-500 mt-4 font-medium text-xl">Histórico de integridade do sistema.</p>
  </header>

  <!-- Filter Bar -->
  <div class="grid grid-cols-12 gap-6 items-end mb-10">
    <div class="col-span-2 flex flex-col gap-3">
      <label class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 ml-8">Agregado</label>
      <Dropdown
        Options="@entityOptions"
        @bind-Value="entityType"
        @bind-Value:after="LoadLogs"
        PaddingClassOverride="py-5"
      />
    </div>

    <div class="col-span-2 flex flex-col gap-3">
      <label class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 ml-8">Evento</label>
      <input
        type="text"
        @bind="eventType"
        @onkeyup="HandleKeyUp"
        class="w-full px-8 py-5 bg-white border-none rounded-[2rem] shadow-xl shadow-gray-100/50 outline-none font-bold text-xs text-gray-900 placeholder:text-gray-300"
        placeholder="Tipo..."
      />
    </div>

    <div class="col-span-2 flex flex-col gap-3">
      <label class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 ml-8">Usuário</label>
      <input
        type="text"
        @bind="userId"
        @onkeyup="HandleKeyUp"
        class="w-full px-8 py-5 bg-white border-none rounded-[2rem] shadow-xl shadow-gray-100/50 outline-none font-bold text-xs text-gray-900 placeholder:text-gray-300"
        placeholder="User ID..."
      />
    </div>

    <div class="col-span-4 flex flex-col gap-3">
      <label class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 ml-8">Período</label>
      <div class="flex bg-white p-2 rounded-[2rem] shadow-xl shadow-gray-100/50 gap-0 items-center border border-gray-50">
        <div class="flex-1 px-4 py-3 hover:bg-gray-50 rounded-2xl transition-colors flex items-center gap-3">
          <label class="text-[10px] font-black uppercase tracking-[0.1em] text-gray-400">De</label>
          <input
            type="date"
            @bind="startDate"
            @bind:after="LoadLogs"
            class="w-full bg-transparent border-none outline-none font-bold text-[10px] text-gray-900 cursor-pointer"
          />
        </div>
        <div class="w-[1px] h-6 bg-gray-100 self-center"></div>
        <div class="flex-1 px-4 py-3 hover:bg-gray-50 rounded-2xl transition-colors flex items-center gap-3">
          <label class="text-[10px] font-black uppercase tracking-[0.1em] text-gray-400">Até</label>
          <input
            type="date"
            @bind="endDate"
            @bind:after="LoadLogs"
            class="w-full bg-transparent border-none outline-none font-bold text-[10px] text-gray-900 cursor-pointer"
          />
        </div>
      </div>
    </div>

    <div class="col-span-2 space-y-3">
      <label class="text-[10px] font-black uppercase tracking-[0.2em] text-transparent ml-4 select-none">Ações</label>
      <div class="flex justify-end">
        <button
          @onclick="ClearFilters"
          class="group flex items-center gap-3 px-8 py-5 text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 hover:text-primary-600 transition-all"
        >
          <span class="group-hover:rotate-180 transition-transform duration-500">🔄</span>
          Limpar
        </button>
      </div>
    </div>
  </div>

  @if (_logs == null) {
    <div class="flex justify-center py-40 bg-white rounded-[3rem] shadow-xl shadow-gray-100/50">
      <div class="w-16 h-16 border-8 border-primary-600 border-t-transparent rounded-full animate-spin"></div>
    </div>
  } else {
    <div class="bg-white rounded-[3rem] shadow-2xl shadow-gray-200/40 border border-gray-50 overflow-hidden">
      <table class="w-full text-left">
        <thead class="bg-primary-600 text-white">
          <tr>
            <th class="px-10 py-8 text-[10px] font-black uppercase tracking-[0.2em]">Evento</th>
            <th class="px-10 py-8 text-[10px] font-black uppercase tracking-[0.2em]">Entidade</th>
            <th class="px-10 py-8 text-[10px] font-black uppercase tracking-[0.2em]">Usuário</th>
            <th class="px-10 py-8 text-[10px] font-black uppercase tracking-[0.2em]">Data</th>
            <th class="px-10 py-8 text-[10px] font-black uppercase tracking-[0.2em]">Ações</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          @foreach (var log in _logs.Items) {
            <tr class="hover:bg-gray-50/50 transition-colors group">
              <td class="px-10 py-8">
                <span class="px-4 py-2 bg-primary-50 text-primary-600 rounded-xl font-black text-[10px] uppercase tracking-widest">
                  @log.EventType
                </span>
              </td>
              <td class="px-10 py-8">
                <div class="flex flex-col">
                  <span class="font-black text-gray-900 tracking-tight">@log.AggregateType</span>
                  <span class="text-[10px] font-bold text-gray-300 uppercase tracking-widest">@log.AggregateId</span>
                </div>
              </td>
              <td class="px-10 py-8">
                <span class="font-bold text-gray-500">@(string.IsNullOrEmpty(log.UserId) ? "Sistema" : log.UserId)</span>
              </td>
              <td class="px-10 py-8">
                <span class="text-xs font-bold text-gray-400">@log.OccurredOn.ToString("g")</span>
              </td>
              <td class="px-10 py-8">
                <div class="flex gap-2 group-hover:opacity-100 transition-opacity">
                  <button 
                    @onclick="() => ShowDetails(log)"
                    class="p-3 hover:bg-primary-50 rounded-xl text-primary-600 transition-colors"
                    title="Ver Detalhes"
                  >
                    🔍
                  </button>
                </div>
              </td>
            </tr>
          }
        </tbody>
      </table>

      <Pagination 
        Page="@currentPage" 
        TotalPages="@_logs.TotalPages" 
        TotalItems="@_logs.TotalCount" 
        PageSize="@pageSize"
        OnPageChanged="ChangePage"
        OnPageSizeChanged="ChangePageSize"
      />
    </div>
  }

  <Modal Show="@(selectedLog != null)" Title="Detalhes do Evento" MaxWidth="max-w-5xl" OnClose="() => selectedLog = null">
    @if (selectedLog != null)
    {
        <div class="space-y-6">
            <div class="flex items-center gap-4">
                <span class="px-4 py-1.5 bg-primary-600 text-white rounded-xl text-[10px] font-black uppercase tracking-[0.2em] shadow-lg shadow-primary-600/20">
                    @selectedLog.EventType
                </span>
                <div class="h-px flex-1 bg-gray-100"></div>
            </div>

            <div class="grid grid-cols-3 gap-4">
                <div class="bg-gray-50/50 p-6 rounded-[2rem] border border-gray-100/50">
                    <label class="text-[10px] font-black uppercase tracking-widest text-gray-400 block mb-2 ml-1">Entidade</label>
                    <p class="font-black text-gray-900 text-xl tracking-tight">@selectedLog.AggregateType</p>
                    <p class="text-gray-400 font-mono text-[9px] mt-1">ID: @selectedLog.AggregateId</p>
                </div>
                <div class="bg-gray-50/50 p-6 rounded-[2rem] border border-gray-100/50">
                    <label class="text-[10px] font-black uppercase tracking-widest text-gray-400 block mb-2 ml-1">Metadata</label>
                    <p class="font-black text-gray-900 text-xl tracking-tight">@selectedLog.OccurredOn.ToString("g")</p>
                    <p class="text-gray-400 text-[9px] font-bold uppercase tracking-widest mt-1">Versão: @selectedLog.Version</p>
                </div>
                <div class="bg-gray-50/50 p-6 rounded-[2rem] border border-gray-100/50">
                    <label class="text-[10px] font-black uppercase tracking-widest text-gray-400 block mb-2 ml-1">Usuário</label>
                    <p class="font-black text-gray-900 text-xl tracking-tight">@(string.IsNullOrEmpty(selectedLog.UserId) ? "Sistema" : selectedLog.UserId)</p>
                    <p class="text-gray-400 text-[9px] font-bold uppercase tracking-widest mt-1">Origin: API</p>
                </div>
            </div>

            <div class="bg-gray-900 rounded-[2.5rem] p-8 shadow-xl shadow-gray-900/30 relative">
                <label class="text-[10px] font-black uppercase tracking-widest text-gray-500 block mb-4 ml-2">Payload (JSON)</label>
                <div class="overflow-hidden rounded-xl bg-gray-950/50 p-5 border border-white/5">
                    <pre class="text-primary-300 font-mono text-xs overflow-x-auto leading-relaxed max-h-[350px] scrollbar-thin scrollbar-thumb-gray-800 scrollbar-track-transparent">@GetEventDataJson(selectedLog.EventData)</pre>
                </div>
            </div>

            <div class="flex justify-end pt-2">
                <button 
                    @onclick="() => selectedLog = null"
                    class="bg-primary-600 hover:bg-primary-700 text-white font-black px-8 py-4 rounded-2xl shadow-lg shadow-primary-600/20 transition-all active:scale-95"
                >
                    FECHAR DETALHES
                </button>
            </div>
        </div>
    }
  </Modal>
</div>

@code {
    private PagedResponse<DomainEvent>? _logs;
    private DomainEvent? selectedLog;
    private int currentPage = 1;
    private int pageSize = 10;
    private object? entityType = "";
    private string eventType = "";
    private string userId = "";
    private DateTime? startDate;
    private DateTime? endDate;

    private List<DropdownOption> entityOptions = new() {
        new() { Label = "Todos", Value = "" },
        new() { Label = "Pedidos", Value = "Order" },
        new() { Label = "Produtos", Value = "Product" }
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadLogs();
    }

    private void ShowDetails(DomainEvent log)
    {
        selectedLog = log;
    }

    private string GetEventDataJson(object? data)
    {
        if (data == null) return "{}";
        try 
        {
            return System.Text.Json.JsonSerializer.Serialize(data, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        }
        catch 
        {
            return data.ToString() ?? "{}";
        }
    }

    private async Task LoadLogs()
    {
        try
        {
            _logs = null;
            _logs = await AuditService.GetAuditLogsAsync(
                currentPage,
                pageSize,
                entityType?.ToString(),
                eventType,
                userId,
                startDate,
                endDate);
        }
        catch (Exception)
        {
            _logs = new PagedResponse<DomainEvent> { Items = new List<DomainEvent>(), TotalCount = 0 };
        }
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            currentPage = 1;
            await LoadLogs();
        }
    }

    private async Task ChangePage(int newPage)
    {
        currentPage = newPage;
        await LoadLogs();
    }

    private async Task ChangePageSize(int newSize)
    {
        pageSize = newSize;
        currentPage = 1;
        await LoadLogs();
    }

    private async Task ClearFilters()
    {
        entityType = "";
        eventType = "";
        userId = "";
        startDate = null;
        endDate = null;
        currentPage = 1;
        await LoadLogs();
    }
}
