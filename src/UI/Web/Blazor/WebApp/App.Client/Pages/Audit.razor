@page "/audit"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using BlazorApp.Client.Services
@using ProjectTemplate.SharedModels
@using ProjectTemplate.Domain.Entities
@inject IAuditService AuditService
@rendermode InteractiveAuto

<div class="p-12 max-w-[1600px] mx-auto animate-in fade-in duration-700">
  <header class="mb-12">
    <h1 class="text-5xl font-black text-gray-900 tracking-tighter">Auditoria</h1>
    <p class="text-gray-500 mt-3 font-medium text-lg">Histórico de integridade do sistema.</p>
  </header>

  <!-- Filter Bar -->
  <div class="grid grid-cols-12 gap-6 items-end mb-10">
    <div class="col-span-2 space-y-3">
      <label class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 ml-4">Agregado</label>
      <Dropdown 
        Options="@entityOptions"
        @bind-Value="entityType"
        @bind-Value:after="LoadLogs"
      />
    </div>

    <div class="col-span-3 space-y-3">
      <label class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 ml-4">Evento</label>
      <input 
        type="text" 
        @bind="eventType"
        @onkeyup="HandleKeyUp"
        class="w-full px-8 py-5 bg-white border-none rounded-3xl shadow-xl shadow-gray-100/50 outline-none font-bold text-gray-900 placeholder:text-gray-300"
        placeholder="Tipo..."
      />
    </div>

    <div class="col-span-3 space-y-3">
      <label class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 ml-4">Usuário</label>
      <input 
        type="text" 
        @bind="userId"
        @onkeyup="HandleKeyUp"
        class="w-full px-8 py-5 bg-white border-none rounded-3xl shadow-xl shadow-gray-100/50 outline-none font-bold text-gray-900 placeholder:text-gray-300"
        placeholder="User ID..."
      />
    </div>

    <div class="col-span-2 flex justify-end">
      <button 
        @onclick="ClearFilters"
        class="group flex items-center gap-3 px-8 py-5 text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 hover:text-primary-600 transition-all"
      >
        <span class="group-hover:rotate-180 transition-transform duration-500">🔄</span>
        Limpar
      </button>
    </div>
  </div>

  @if (_logs == null) {
    <div class="flex justify-center py-40 bg-white rounded-[3rem] shadow-xl shadow-gray-100/50">
      <div class="w-16 h-16 border-8 border-primary-600 border-t-transparent rounded-full animate-spin"></div>
    </div>
  } else {
    <div class="bg-white rounded-[3rem] shadow-2xl shadow-gray-200/40 border border-gray-50 overflow-hidden">
      <table class="w-full text-left">
        <thead>
          <tr class="bg-gray-50/50">
            <th class="px-10 py-8 text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]">Evento</th>
            <th class="px-10 py-8 text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]">Entidade</th>
            <th class="px-10 py-8 text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]">Usuário</th>
            <th class="px-10 py-8 text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]">Data</th>
            <th class="px-10 py-8 text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]">Ações</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          @foreach (var log in _logs.Items) {
            <tr class="hover:bg-gray-50/50 transition-colors group">
              <td class="px-10 py-8">
                <span class="px-4 py-2 bg-primary-50 text-primary-600 rounded-xl font-black text-[10px] uppercase tracking-widest">
                  @log.EventType
                </span>
              </td>
              <td class="px-10 py-8">
                <div class="flex flex-col">
                  <span class="font-black text-gray-900 tracking-tight">@log.AggregateType</span>
                  <span class="text-[10px] font-bold text-gray-300 uppercase tracking-widest">@log.AggregateId</span>
                </div>
              </td>
              <td class="px-10 py-8">
                <span class="font-bold text-gray-500">@(string.IsNullOrEmpty(log.UserId) ? "Sistema" : log.UserId)</span>
              </td>
              <td class="px-10 py-8">
                <span class="text-xs font-bold text-gray-400">@log.OccurredOn.ToString("g")</span>
              </td>
              <td class="px-10 py-8">
                <div class="flex gap-2 group-hover:opacity-100 transition-opacity">
                  <button class="p-3 hover:bg-primary-50 rounded-xl text-primary-600 transition-colors">🔍</button>
                </div>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>

    <Pagination 
      Page="@currentPage" 
      TotalPages="@_logs.TotalPages" 
      TotalItems="@_logs.TotalCount" 
      PageSize="@pageSize"
      OnPageChanged="ChangePage"
      OnPageSizeChanged="ChangePageSize"
    />
  }
</div>

@code {
    private PagedResponse<DomainEvent>? _logs;
    private int currentPage = 1;
    private int pageSize = 10;
    private object? entityType = "";
    private string eventType = "";
    private string userId = "";

    private List<DropdownOption> entityOptions = new() {
        new() { Label = "Todos", Value = "" },
        new() { Label = "Pedidos", Value = "Order" },
        new() { Label = "Produtos", Value = "Product" }
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadLogs();
    }

    private async Task LoadLogs()
    {
        try 
        {
            _logs = null;
            _logs = await AuditService.GetAuditLogsAsync(currentPage, pageSize, entityType?.ToString());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar logs: {ex.Message}");
        }
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            currentPage = 1;
            await LoadLogs();
        }
    }

    private async Task ChangePage(int newPage)
    {
        currentPage = newPage;
        await LoadLogs();
    }

    private async Task ChangePageSize(int newSize)
    {
        pageSize = newSize;
        currentPage = 1;
        await LoadLogs();
    }

    private async Task ClearFilters()
    {
        entityType = "";
        eventType = "";
        userId = "";
        currentPage = 1;
        await LoadLogs();
    }
}
