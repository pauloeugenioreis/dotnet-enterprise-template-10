@page "/audit"
@using BlazorApp.Client.Services
@using ProjectTemplate.SharedModels
@inject IAuditService AuditService
@attribute [Authorize]

<PageTitle>Auditoria - Enterprise Template</PageTitle>

<div class="p-4 sm:p-8 max-w-7xl mx-auto animate-fade-in">
    <div class="mb-8">
        <h1 class="text-3xl font-black text-gray-900 tracking-tight">Trilhas de Auditoria</h1>
        <p class="text-gray-500 mt-2 font-medium">Histórico de eventos e alterações no sistema.</p>
    </div>

    @if (_loading)
    {
        <div class="flex items-center justify-center h-64">
            <div class="w-12 h-12 border-4 border-primary-600 border-t-transparent rounded-full animate-spin"></div>
        </div>
    }
    else if (_logs == null || !_logs.Items.Any())
    {
        <div class="bg-white rounded-3xl p-12 text-center border border-gray-100 shadow-sm">
            <div class="w-20 h-20 bg-gray-50 rounded-2xl flex items-center justify-center mx-auto mb-4 text-gray-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
            </div>
            <h3 class="text-lg font-bold text-gray-900">Nenhum log encontrado</h3>
            <p class="text-gray-500">O sistema de auditoria está ativo e aguardando eventos.</p>
        </div>
    }
    else
    {
        <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50/50 border-b border-gray-100">
                        <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider">Evento</th>
                        <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider">Entidade</th>
                        <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider">Usuário</th>
                        <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider">Data/Hora</th>
                        <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider">Versão</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var log in _logs.Items)
                    {
                        <tr class="hover:bg-gray-50/50 transition-colors">
                            <td class="px-6 py-4">
                                <span class="px-3 py-1 bg-primary-50 text-primary-600 rounded-full text-xs font-bold">
                                    @log.EventType
                                </span>
                            </td>
                            <td class="px-6 py-4">
                                <div class="text-sm font-bold text-gray-900">@log.AggregateType</div>
                                <div class="text-xs text-gray-400">ID: @log.AggregateId</div>
                            </td>
                            <td class="px-6 py-4 text-sm text-gray-500">@log.UserId</td>
                            <td class="px-6 py-4 text-sm text-gray-500">@log.OccurredOn.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="px-6 py-4">
                                <span class="text-xs font-mono bg-gray-100 px-2 py-1 rounded">v@log.Version</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private PagedResponse<DomainEvent>? _logs;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Buscando logs de Order por padrão para o MVP
            _logs = await AuditService.GetAuditLogsAsync("Order");
        }
        finally
        {
            _loading = false;
        }
    }
}
