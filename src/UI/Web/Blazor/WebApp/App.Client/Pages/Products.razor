@page "/products"
@using BlazorApp.Client.Services
@using BlazorApp.Components.UI
@using ProjectTemplate.SharedModels
@inject IProductService ProductService
@rendermode InteractiveAuto

<div class="mb-8 flex justify-between items-end">
    <div>
        <h1 class="text-3xl font-bold text-gray-900 tracking-tight">Produtos</h1>
        <p class="text-gray-500 mt-2">Gerencie seu inventário com eficiência e clareza.</p>
    </div>
    <button class="bg-primary-600 text-white px-5 py-2.5 rounded-xl text-sm font-bold hover:bg-primary-700 transition-all shadow-lg shadow-primary-200 flex items-center gap-2 group">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:rotate-90 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Novo Produto
    </button>
</div>

<!-- Products Table Card -->
<div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="p-6 border-b border-gray-100 flex justify-between items-center bg-gray-50/30">
        <div class="flex items-center gap-4">
            <div class="px-3 py-1 bg-primary-50 text-primary-700 rounded-full text-xs font-bold uppercase tracking-wider">
                Total: @(products?.TotalCount ?? 0)
            </div>
        </div>
    </div>

    @if (products == null)
    {
        <div class="p-20 flex flex-col items-center justify-center gap-4">
            <div class="w-12 h-12 border-4 border-primary-100 border-t-primary-600 rounded-full animate-spin"></div>
            <p class="text-gray-400 text-sm font-medium animate-pulse">Sincronizando dados...</p>
        </div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="text-[11px] uppercase tracking-[0.1em] text-gray-400 border-b border-gray-100 bg-gray-50/50">
                        <th class="px-8 py-5 font-bold">Produto / ID</th>
                        <th class="px-8 py-5 font-bold">Categoria</th>
                        <th class="px-8 py-5 font-bold text-right">Preço Unitário</th>
                        <th class="px-8 py-5 font-bold text-center">Status de Estoque</th>
                        <th class="px-8 py-5 font-bold"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var item in products.Items)
                    {
                        <tr class="hover:bg-gray-50/80 transition-all group">
                            <td class="px-8 py-5">
                                <div class="flex items-center gap-4">
                                    <div class="w-11 h-11 bg-gray-100 rounded-xl flex items-center justify-center text-gray-400 group-hover:bg-primary-600 group-hover:text-white transition-all shadow-sm">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                                        </svg>
                                    </div>
                                    <div>
                                        <p class="font-bold text-gray-800 text-sm">@item.Name</p>
                                        <p class="text-[10px] text-gray-400 font-mono mt-1 uppercase">Ref: #@item.Id</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-8 py-5">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium bg-gray-100 text-gray-800">
                                    @item.Category
                                </span>
                            </td>
                            <td class="px-8 py-5 text-right">
                                <span class="font-bold text-gray-900 text-sm">@item.Price.ToString("C")</span>
                            </td>
                            <td class="px-8 py-5 text-center">
                                @if (item.Stock > 10)
                                {
                                    <div class="flex flex-col items-center gap-1">
                                        <span class="px-2 py-1 bg-emerald-50 text-emerald-700 text-[10px] font-bold uppercase rounded-md tracking-wider">Disponível</span>
                                        <span class="text-[10px] text-gray-400 italic">@item.Stock unidades</span>
                                    </div>
                                }
                                else if (item.Stock > 0)
                                {
                                    <div class="flex flex-col items-center gap-1">
                                        <span class="px-2 py-1 bg-amber-50 text-amber-700 text-[10px] font-bold uppercase rounded-md tracking-wider">Baixo Estoque</span>
                                        <span class="text-[10px] text-amber-600 font-medium">Restam @item.Stock</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="px-2 py-1 bg-rose-50 text-rose-700 text-[10px] font-bold uppercase rounded-md tracking-wider">Esgotado</span>
                                }
                            </td>
                            <td class="px-8 py-5 text-right">
                                <div class="flex justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <button class="p-2 text-gray-400 hover:text-primary-600 hover:bg-primary-50 rounded-lg transition-all" title="Editar">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                                        </svg>
                                    </button>
                                    <button class="p-2 text-gray-400 hover:text-rose-600 hover:bg-rose-50 rounded-lg transition-all" title="Excluir">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                        </svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <Pagination 
            T="ProductResponseDto"
            CurrentPage="@currentPage"
            TotalPages="@products.TotalPages"
            HasNextPage="@products.HasNextPage"
            HasPreviousPage="@products.HasPreviousPage"
            OnPageChanged="ChangePage" />
    }
</div>

@code {
    private PagedResponse<ProductResponseDto>? products;
    private int currentPage = 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        products = null;
        try 
        {
            products = await ProductService.GetPagedAsync(currentPage, 10);
        }
        catch (Exception ex)
        {
            // Em um cenário real, usaríamos um serviço de notificação (Toast)
            Console.WriteLine($"Erro ao carregar produtos: {ex.Message}");
        }
    }

    private async Task ChangePage(int newPage)
    {
        currentPage = newPage;
        await LoadProducts();
    }
}
