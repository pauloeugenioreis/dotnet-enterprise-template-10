@page "/reviews"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using BlazorApp.Client.Services
@using BlazorApp.Components.UI
@using ProjectTemplate.SharedModels
@inject ICustomerReviewService ReviewService
@rendermode InteractiveAuto

<div class="mb-8 flex justify-between items-end">
    <div>
        <h1 class="text-3xl font-bold text-gray-900 tracking-tight">Avaliações</h1>
        <p class="text-gray-500 mt-2">Veja o que seus clientes estão dizendo sobre seus produtos.</p>
    </div>
    <div class="flex items-center gap-2 bg-amber-50 px-4 py-2 rounded-xl border border-amber-100">
        <span class="text-amber-600 font-black text-xl">4.9</span>
        <div class="flex text-amber-400">
            @for(int i=0; i<5; i++) {
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 fill-current" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
            }
        </div>
        <span class="text-amber-700 text-xs font-bold ml-1">Média Global</span>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    @if (reviews == null)
    {
        @for(int i=0; i<6; i++) {
            <div class="bg-white p-6 rounded-[2rem] border border-gray-100 shadow-sm animate-pulse">
                <div class="flex items-center gap-4 mb-4">
                    <div class="w-12 h-12 bg-gray-100 rounded-full"></div>
                    <div class="space-y-2">
                        <div class="h-4 w-32 bg-gray-100 rounded"></div>
                        <div class="h-3 w-20 bg-gray-50 rounded"></div>
                    </div>
                </div>
                <div class="h-20 bg-gray-50 rounded-2xl mb-4"></div>
                <div class="h-4 w-full bg-gray-50 rounded"></div>
            </div>
        }
    }
    else
    {
        @foreach (var review in reviews.Items)
        {
            <div class="bg-white p-6 rounded-[2rem] border border-gray-100 shadow-sm hover:shadow-xl hover:shadow-primary-500/5 transition-all group">
                <div class="flex justify-between items-start mb-6">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 bg-primary-100 text-primary-600 rounded-full flex items-center justify-center font-black text-lg">
                            @review.CustomerName[0]
                        </div>
                        <div>
                            <h3 class="font-bold text-gray-800">@review.CustomerName</h3>
                            <p class="text-[10px] text-gray-400 font-medium">@review.CreatedAt.ToString("dd MMM, yyyy")</p>
                        </div>
                    </div>
                    <div class="flex text-amber-400">
                        @for(int i=0; i<review.Rating; i++) {
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 fill-current" viewBox="0 0 20 20">
                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                            </svg>
                        }
                    </div>
                </div>

                <div class="bg-gray-50/50 rounded-2xl p-4 mb-4">
                    <h4 class="font-bold text-gray-700 text-sm mb-2">"@review.Title"</h4>
                    <p class="text-gray-500 text-xs leading-relaxed italic">@review.Comment</p>
                </div>

                <div class="flex justify-between items-center mt-6">
                    <div class="flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
                        <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">@review.ProductName</span>
                    </div>
                    <button class="text-primary-600 text-[10px] font-black uppercase hover:underline">Responder</button>
                </div>
            </div>
        }
    }
</div>

<div class="mt-10">
    @if (reviews != null)
    {
        <Pagination 
            T="CustomerReviewResponseDto"
            CurrentPage="@currentPage"
            TotalPages="@reviews.TotalPages"
            HasNextPage="@reviews.HasNextPage"
            HasPreviousPage="@reviews.HasPreviousPage"
            OnPageChanged="ChangePage" />
    }
</div>

@code {
    private PagedResponse<CustomerReviewResponseDto>? reviews;
    private int currentPage = 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadReviews();
    }

    private async Task LoadReviews()
    {
        reviews = null;
        try 
        {
            reviews = await ReviewService.GetPagedAsync(currentPage, 9);
        }
        catch (Exception)
        {
            reviews = GetMockReviews();
        }
    }

    private async Task ChangePage(int newPage)
    {
        currentPage = newPage;
        await LoadReviews();
    }

    private PagedResponse<CustomerReviewResponseDto> GetMockReviews()
    {
        return new PagedResponse<CustomerReviewResponseDto>
        {
            Items = new List<CustomerReviewResponseDto>
            {
                new() { CustomerName = "Carlos Mendes", Rating = 5, Title = "Excelente Produto!", Comment = "O acabamento é impecável e a performance superou minhas expectativas.", ProductName = "MacBook Pro M3", CreatedAt = DateTime.Now.AddDays(-2) },
                new() { CustomerName = "Ana Paula", Rating = 4, Title = "Muito bom", Comment = "Gostei bastante, apenas a entrega que demorou um pouco mais que o previsto.", ProductName = "iPhone 15 Pro", CreatedAt = DateTime.Now.AddDays(-5) },
                new() { CustomerName = "Roberto Silva", Rating = 5, Title = "Recomendo a todos", Comment = "Qualidade premium em cada detalhe. Vale cada centavo investido.", ProductName = "Monitor Studio Display", CreatedAt = DateTime.Now.AddDays(-1) },
                new() { CustomerName = "Juliana Lima", Rating = 5, Title = "Perfeito", Comment = "Simplesmente incrível. O melhor que já comprei até hoje.", ProductName = "AirPods Max", CreatedAt = DateTime.Now.AddDays(-10) }
            },
            TotalCount = 4,
            TotalPages = 1,
            PageNumber = 1,
            PageSize = 9
        };
    }
}
